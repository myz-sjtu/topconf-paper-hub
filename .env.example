APP_NAME=TopConf Paper Hub
APP_ENV=development
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite:///./topconf_papers.db
REDIS_URL=redis://localhost:6379/0
CONFERENCE_CONFIG_PATH=configs/conferences/top_conferences.yaml
TAXONOMY_CONFIG_PATH=configs/taxonomy/tags.yaml
REQUEST_TIMEOUT_SECONDS=20
CRAWLER_USER_AGENT=TopConfPaperHub/0.1 (+metadata-only academic crawler)
DEFAULT_YEAR_WINDOW=5
SCHEDULER_ENABLED=false
SCHEDULER_HOUR_UTC=2
